# ---- Models ----
LLM_MODEL=qwen2.5:3b
EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://ollama:11434

# ---- Vector DB ----
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=hdb_docs

# ---- Relational DB ----
POSTGRES_USER=hdb
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=hdbbot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Auth ----
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=60
DEMO_USER=demo
DEMO_PASSWORD=demo12345

# ---- Guardrails / RAG ----
TOP_K=4
GUARDRAILS_CONFIG_PATH=/app/config

# ---- Optional crawler tuning ----
INGEST_REQUEST_TIMEOUT=60

# ---- Agent (Azure Function) ----
ELIGIBILITY_AGENT_URL=

# ---- MCP ----
MCP_URL=http://mcp-server:9000/sse

# ---- Telemetry ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=hdb-chatbot-api
